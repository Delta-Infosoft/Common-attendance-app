<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/txtLayState"
            style="@style/CommonTextInputLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="10dp"
            app:endIconDrawable="@drawable/ic_arrow_drop_down"
            app:endIconMode="custom"
            app:endIconTint="@color/primary"
            app:layout_constraintEnd_toStartOf="@id/txtLayDistrict"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/txtState"
                style="@style/CommonTextInputEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:cursorVisible="false"
                android:focusable="false"
                android:hint="@string/hint_state"
                android:inputType="none"
                tools:text="Gujarat" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/txtLayDistrict"
            style="@style/CommonTextInputLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="10dp"
            app:endIconDrawable="@drawable/ic_arrow_drop_down"
            app:endIconMode="custom"
            app:endIconTint="@color/primary"
            app:layout_constraintBottom_toBottomOf="@id/txtLayState"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/txtLayState"
            app:layout_constraintTop_toTopOf="@id/txtLayState">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/txtDistrict"
                style="@style/CommonTextInputEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:cursorVisible="false"
                android:focusable="false"
                android:hint="@string/hint_district"
                android:inputType="none"
                tools:text="Junagadh" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/txtLayBusinessCenter"
            style="@style/CommonTextInputLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            app:endIconDrawable="@drawable/ic_arrow_drop_down"
            app:endIconMode="custom"
            app:endIconTint="@color/primary"
            app:layout_constraintEnd_toEndOf="@id/txtLayState"
            app:layout_constraintStart_toStartOf="@id/txtLayState"
            app:layout_constraintTop_toBottomOf="@id/txtLayDistrict">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/txtBusinessCenter"
                style="@style/CommonTextInputEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:cursorVisible="false"
                android:focusable="false"
                android:hint="@string/hint_business_center"
                android:inputType="none"
                tools:text="Junagadh" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/txtLayDealerCategory"
            style="@style/CommonTextInputLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            app:endIconDrawable="@drawable/ic_arrow_drop_down"
            app:endIconMode="custom"
            app:endIconTint="@color/primary"
            app:layout_constraintBottom_toBottomOf="@id/txtLayBusinessCenter"
            app:layout_constraintEnd_toEndOf="@id/txtLayDistrict"
            app:layout_constraintStart_toStartOf="@id/txtLayDistrict"
            app:layout_constraintTop_toTopOf="@id/txtLayBusinessCenter">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/txtDealerCategory"
                style="@style/CommonTextInputEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:cursorVisible="false"
                android:focusable="false"
                android:hint="@string/hint_dealer_category"
                android:inputType="none"
                tools:text="Car" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/txtLayDealerName"
            style="@style/CommonTextInputLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="@id/txtLayDealerCategory"
            app:layout_constraintStart_toStartOf="@id/txtLayBusinessCenter"
            app:layout_constraintTop_toBottomOf="@id/txtLayDealerCategory">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/txtDealerName"
                style="@style/CommonTextInputEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_dealer_name"
                android:inputType="text"
                tools:text="Car" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/txtLaySubDealerName"
            style="@style/CommonTextInputLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="@id/txtLayDealerCategory"
            app:layout_constraintStart_toStartOf="@id/txtLayBusinessCenter"
            app:layout_constraintTop_toBottomOf="@id/txtLayDealerName">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/txtSubDealerName"
                style="@style/CommonTextInputEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:cursorVisible="false"
                android:focusable="false"
                android:hint="@string/hint_sub_dealer_name"
                android:inputType="none"
                tools:text="Car" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/txtLayServiceCenter"
            style="@style/CommonTextInputLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="@id/txtLayDealerCategory"
            app:layout_constraintStart_toStartOf="@id/txtLayBusinessCenter"
            app:layout_constraintTop_toBottomOf="@id/txtLaySubDealerName">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/txtServiceCenter"
                style="@style/CommonTextInputEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:cursorVisible="false"
                android:focusable="false"
                android:hint="@string/hint_service_center"
                android:inputType="none"
                tools:text="Car" />

        </com.google.android.material.textfield.TextInputLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txtLayServiceCenter"
            tools:itemCount="1"
            tools:listitem="@layout/row_item_tour_agenda_tracking_listing_1" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/constStartEndMeeting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            app:layout_constraintEnd_toEndOf="@id/txtLayDealerCategory"
            app:layout_constraintStart_toStartOf="@id/txtLayBusinessCenter"
            app:layout_constraintTop_toBottomOf="@id/recyclerView1">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/btnStartMeeting"
                style="@style/kumbh.bold.white.14"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="2dp"
                android:background="@drawable/bg_primary_rounded_18"
                android:backgroundTint="@color/red_1"
                android:paddingHorizontal="10dp"
                android:paddingVertical="10dp"
                android:text="@string/btn_start_meeting"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/btnEndMeeting"
                style="@style/kumbh.bold.white.14"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:background="@drawable/bg_primary_rounded_18"
                android:backgroundTint="@color/red_1"
                android:paddingHorizontal="10dp"
                android:paddingVertical="10dp"
                android:text="@string/label_end_meeting"
                app:layout_constraintStart_toEndOf="@id/btnStartMeeting"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/txtViewMeetingTimer"
                style="@style/kumbh.regular.black.16"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="00.00" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/constCheckInOut"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:layout_constraintEnd_toEndOf="@id/constStartEndMeeting"
            app:layout_constraintStart_toStartOf="@id/constStartEndMeeting"
            app:layout_constraintTop_toBottomOf="@id/constStartEndMeeting">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/txtCheckInTime"
                style="@style/kumbh.bold.black.16"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/label_check_in"
                app:layout_constraintEnd_toStartOf="@id/txtCheckOutTime"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/txtViewCheckInTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toEndOf="@id/txtCheckInTime"
                app:layout_constraintStart_toStartOf="@id/txtCheckInTime"
                app:layout_constraintTop_toBottomOf="@id/txtCheckInTime"
                tools:text="12:00 AM" />

            <View
                android:id="@+id/viewVertical"
                android:layout_width="1dp"
                android:layout_height="0dp"
                android:background="@color/gray"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/txtCheckOutTime"
                app:layout_constraintStart_toEndOf="@id/txtCheckInTime"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/txtCheckOutTime"
                style="@style/kumbh.bold.black.16"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:text="@string/label_check_out"
                app:layout_constraintEnd_toStartOf="@id/txtViewTotalCheckInOutTimer"
                app:layout_constraintStart_toEndOf="@id/txtCheckInTime"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/txtViewCheckOutTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toEndOf="@id/txtCheckOutTime"
                app:layout_constraintStart_toStartOf="@id/txtCheckOutTime"
                app:layout_constraintTop_toBottomOf="@id/txtCheckOutTime"
                tools:text="12:00 AM" />


            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/txtViewTotalCheckInOutTimer"
                style="@style/kumbh.regular.black.16"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="00.00" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/constCheckInOut"
            app:layout_constraintVertical_bias="0"
            tools:itemCount="1"
            tools:listitem="@layout/row_item_tour_agenda_tracking_listing_1" />


        <ProgressBar
            android:id="@+id/progressBarHome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_primary_rounded_18"
            android:elevation="5dp"
            android:indeterminate="true"
            android:indeterminateTint="@color/white"
            android:indeterminateTintMode="src_in"
            android:padding="10dp"
            android:translationZ="5dp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
