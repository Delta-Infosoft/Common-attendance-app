<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.cardview.widget.CardView
        android:id="@+id/cardView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"
        android:outlineSpotShadowColor="@android:color/transparent"
        app:cardCornerRadius="10dp"
        app:cardElevation="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/constLayMain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_edit_text_white_rounded_15">

            <View
                android:id="@+id/viewStart"
                android:layout_width="6dp"
                android:layout_height="0dp"
                android:background="@color/primary"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.appcompat.widget.AppCompatCheckBox
                android:id="@+id/chekBoxItem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:gravity="center"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:layout_marginStart="2dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/viewStart"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/txtViewTitle"
                style="@style/kumbh.bold.black.16"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="15dp"
                android:layout_marginTop="10dp"
                android:background="@android:color/transparent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/chekBoxItem"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="Budget Vs Achieved" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/txtDetailsTextView"
                style="@style/kumbh.regular.black.16"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                app:layout_constraintEnd_toEndOf="@id/txtViewTitle"
                app:layout_constraintStart_toStartOf="@id/txtViewTitle"
                app:layout_constraintTop_toBottomOf="@id/txtViewTitle"
                tools:text="150 / 100 - Running Less in Target" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/txtInsertedOn"
                style="@style/kumbh.regular.black.16"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toEndOf="@id/txtDetailsTextView"
                app:layout_constraintStart_toStartOf="@id/txtViewTitle"
                app:layout_constraintTop_toBottomOf="@id/txtDetailsTextView"
                tools:text="150 / 100 - Running Less in Target" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/txtSalesCurrentYear"
                style="@style/kumbh.regular.black.16"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toEndOf="@id/txtInsertedOn"
                app:layout_constraintStart_toStartOf="@id/txtInsertedOn"
                app:layout_constraintTop_toBottomOf="@id/txtInsertedOn"
                tools:text="2025" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/txtBudgetCurrentYear"
                style="@style/kumbh.regular.black.16"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="@id/txtSalesCurrentYear"
                app:layout_constraintStart_toStartOf="@id/txtSalesCurrentYear"
                app:layout_constraintTop_toBottomOf="@id/txtSalesCurrentYear"
                tools:text="2026" />


        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>


</androidx.constraintlayout.widget.ConstraintLayout>