<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@color/white"
    android:paddingBottom="16dp">

    <!-- Warning Icon -->
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/imgWarning"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/ic_danger"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- Error Message -->
    <TextView
        android:id="@+id/txtViewErrorText"
        style="@style/kumbh.regular.black.14"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        tools:text="You had not filed PJC details of selected date. So please first add your PJC details of selected date."
        android:gravity="center"
        android:layout_margin="15dp"
        app:layout_constraintTop_toBottomOf="@id/imgWarning"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Page Name -->
    <TextView
        android:id="@+id/txtViewPageName"
        android:layout_width="0dp"
        style="@style/kumbh.regular.black.14"
        android:layout_height="wrap_content"
        android:gravity="center"
        tools:text="Would you like to open Daily tour details form ?"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"
        android:layout_marginBottom="15dp"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/txtViewErrorText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- NO Button -->
    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/btnNo"
        android:layout_width="0dp"
        style="@style/button_white_rounded"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_edit_text_white_rounded_15"
        android:text="@string/btn_no"
        android:textSize="16sp"
        android:gravity="center"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/txtViewPageName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnYes"
        app:layout_constraintWidth_percent="0.45"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp" />

    <!-- YES Button -->
    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/btnYes"
        style="@style/button_primary_rounded"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/btn_yes"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:gravity="center"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="@id/btnNo"
        app:layout_constraintStart_toEndOf="@id/btnNo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_percent="0.45"
        android:layout_marginEnd="16dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
