<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="button_white_rounded">
        <item name="android:background">@drawable/bg_white_rounded_18</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:paddingTop">18dp</item>
        <item name="android:paddingBottom">18sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="button_primary_rounded">
        <item name="android:background">@drawable/bg_white_rounded_18</item>
        <item name="android:backgroundTint">@color/primary</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:paddingTop">13dp</item>
        <item name="android:paddingBottom">13sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="BaseEditText">
        <item name="android:background">@drawable/bg_edit_text_white_rounded_15</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingTop">21dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingBottom">21dp</item>
        <item name="android:fontFamily">@font/kumbh_sans_regular</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textColorHint">@color/gray</item>
        <item name="android:inputType">text</item>
        <item name="android:imeOptions">actionNext</item>
    </style>

    <style name="CommonTextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <!-- Hint -->
        <item name="hintTextColor">@color/gray</item>

        <!-- Box -->
        <item name="boxStrokeColor">@color/gray</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxCornerRadiusTopStart">6dp</item>
        <item name="boxCornerRadiusTopEnd">6dp</item>
        <item name="boxCornerRadiusBottomStart">6dp</item>
        <item name="boxCornerRadiusBottomEnd">6dp</item>

        <!-- Error -->
        <item name="errorEnabled">false</item>
    </style>

    <style name="CommonTextInputEditText" parent="Widget.MaterialComponents.TextInputEditText.OutlinedBox">
        <!-- Text -->
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">16sp</item>
        <item name="android:imeOptions">actionNext</item>
        <item name="android:inputType">text</item>
        <item name="maxLines">1</item>

        <!-- Hint -->
        <item name="android:textColorHint">@color/gray</item>
        <item name="hintTextAppearance">@style/CommonHintText</item>

        <!-- Padding -->
        <item name="android:padding">10dp</item>
    </style>

    <style name="CommonHintText" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/gray</item>
    </style>

</resources>